JWT_SECRET=your_jwt_secret_here_min_256_bits
JWT_EXPIRATION=86400

# -- G8: Analyse & Données (URL fournie par le groupe G8) --
G8_BASE_URL=http://g8-service:8080

# -- G7: Suivi des Véhicules --
JWT_SECRET=sgitu_g7_jwt_secret_key_2025
